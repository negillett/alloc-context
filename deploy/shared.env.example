# Example shared host environment — copy to /opt/trading/shared/.env
# Never commit the live file. Mode 640, owner = service user (e.g. trading).

# --- alloc-context (core) ---
ALLOC_CONTEXT_CONFIG=/opt/trading/alloc-context/config/config.yaml
ALLOC_CONTEXT_DB=/opt/trading/alloc-context/state/alloccontext.db

# Optional MCP bind (public x402 listener)
# ALLOC_CONTEXT_MCP_HOST=127.0.0.1
# ALLOC_CONTEXT_MCP_PORT=8000

# x402 pay-per-request (public MCP at https://mcp.yourdomain.com/mcp)
# X402_ENABLED=true
# X402_PAY_TO=0xYourWallet
# X402_PUBLIC_URL=https://mcp.yourdomain.com
# X402_PRICE_MCP=$0.02
#
# Testnet (x402.org facilitator, no CDP keys):
# X402_NETWORK=eip155:84532
# X402_FACILITATOR_URL=https://x402.org/facilitator
#
# Production (CDP facilitator, real USDC on Base mainnet):
# X402_NETWORK=eip155:8453
# X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=

# Exchange + data API keys (see alloc-context/.env.example)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=

# --- alloc-context-operator ---
OPENAI_API_KEY=
RESEND_API_KEY=
RESEND_FROM="AllocContext <onboarding@resend.dev>"
EMAIL_TO=

# Optional operator overrides
# ALLOC_CONTEXT_OPERATOR_CONFIG=/opt/trading/alloc-context-operator/config/config.yaml
